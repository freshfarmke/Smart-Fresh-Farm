{
  "version": 2,
  "rootDirectory": "frontend",
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
